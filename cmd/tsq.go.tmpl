// Insert {{$type}} to db.
{{$precv}}Insert(
	ctx context.Context,
	db gorp.SqlExecutor,
	preAndPostHook ...func(r {{$ptype}}) error,
) error {
	return tsq.TraceDB(ctx, func(ctx context.Context) error {
		if len(preAndPostHook) > 0 {
			if err := preAndPostHook[0](r); err != nil {
				return errors.Annotatef(
					err,
					"pre hook error",
				)
			}
		}

{{- if $dot.CT }}
		r.{{$dot.CT}} = time.Now()
{{- end }}
{{- if $dot.MT }}
		r.{{$dot.MT}} = time.Now()
{{- end }}
		err := db.Insert(r)
		if err != nil {
			return errors.Annotatef(err, "%+v", r)
		}

		if len(preAndPostHook) > 1 {
			if err := preAndPostHook[1](r); err != nil {
				return errors.Annotatef(
					err,
					"post hook error",
				)
			}
		}

		return nil
	})
}


