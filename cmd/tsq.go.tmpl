// SoftDelete soft deletes {{$type}}.
// dt(unix nano timestamp) set delete timestamp manually if it was greater than 0.
{{$precv}}SoftDelete(
	ctx context.Context,
	db gorp.SqlExecutor,
	dt int64,
	preAndPostHook ...func(r {{$ptype}}) error,
) error {
	return tsq.TraceDB(ctx, func(ctx context.Context) error {
		if len(preAndPostHook) > 0 {
			if err := preAndPostHook[0](r); err != nil {
				return errors.Annotatef(
					err,
					"pre hook error",
				)
			}
		}

		if dt > 0 {
			r.{{$dot.DT}} = dt
		} else {
			r.{{$dot.DT}} = time.Now().UnixNano()
		}
	{{- if $dot.MT }}
		r.{{$dot.MT}} = time.Now()
	{{- end }}
		_, err := db.Update(r)
		if err != nil {
			return errors.Annotatef(err, "%+v", r)
		}

		if len(preAndPostHook) > 1 {
			if err := preAndPostHook[1](r); err != nil {
				return errors.Annotatef(
					err,
					"post hook error",
				)
			}
		}

		return nil
	})
}
